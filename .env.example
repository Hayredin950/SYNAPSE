# ============================================================
# SYNAPSE — Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ── Django Core ─────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
# Set DEBUG=False in production — True only for local development
DEBUG=False
# Add your production domain(s) — 0.0.0.0 is NOT safe and must not appear in production
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://synapse_user:synapse_pass@localhost:5432/synapse_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=synapse_db
DB_USER=synapse_user
DB_PASSWORD=synapse_pass

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI / LLM ────────────────────────────────────────────────
# Google Gemini — primary LLM (free tier is generous, no OpenAI needed)
# ── TASK-304: Voice / Whisper transcription ──────────────────
# OpenAI API key — used for Whisper transcription (also works for GPT models)
OPENAI_API_KEY=sk-your_openai_key_here
# Optional: local Whisper model size if not using OpenAI API (tiny/base/small/medium/large)
WHISPER_LOCAL_MODEL=base

# ── TASK-303: AI Agent Tool Expansion ────────────────────────
# Tavily web search (TASK-303-B1) — get key at https://tavily.com
TAVILY_API_KEY=tvly-your_tavily_api_key_here
# PDF reader and chart generator have no API key requirements
# Python sandbox uses no external services

# ── TASK-302: Multi-provider LLM support ─────────────────────
# OpenRouter (routes to GPT-4o, Gemini, Claude, etc.)
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Anthropic Claude (Pro/Enterprise plans only)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# CLAUDE_MODEL_PRIMARY=claude-3-5-sonnet-20241022
# CLAUDE_MODEL_FALLBACK=claude-3-haiku-20240307
# Ollama local LLMs (any plan, free)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_AVAILABLE_MODELS=llama3.2,mistral,codellama,deepseek-r1
# Google Gemini — add up to 10 keys from different Google accounts to
# multiply your daily free-tier quota. Keys are round-robin rotated.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY_1=your-gemini-api-key-2-here
GEMINI_API_KEY_2=your-gemini-api-key-3-here
GEMINI_API_KEY_3=your-gemini-api-key-4-here
GEMINI_API_KEY_4=your-gemini-api-key-5-here
GEMINI_API_KEY_5=your-gemini-api-key-6-here
GEMINI_API_KEY_6=your-gemini-api-key-7-here
GEMINI_API_KEY_7=your-gemini-api-key-8-here
GEMINI_API_KEY_8=your-gemini-api-key-9-here
GEMINI_API_KEY_9=your-gemini-api-key-10-here
GEMINI_API_KEY_10=your-gemini-api-key-11-here
# Add more as GEMINI_API_KEY_3 ... GEMINI_API_KEY_10
GEMINI_MODEL=gemini-flash-latest
# Embeddings: always use local sentence-transformers (no API key needed)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# ── Vector Database ─────────────────────────────────────────
# Option 1: pgvector (recommended — uses existing PostgreSQL)
VECTOR_DB_PROVIDER=pgvector
# Option 2: Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=synapse-embeddings

# ── Data Sources / Scraping ──────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token
YOUTUBE_API_KEY=your-youtube-data-api-v3-key
NEWS_API_KEY=your-newsapi-org-key
# arXiv does not require an API key (public API)
HACKER_NEWS_BASE_URL=https://hacker-news.firebaseio.com/v0
# X (Twitter) API v2 — App-only Bearer Token
X_API_KEY=your-x-twitter-bearer-token

# ── Cloud Storage: AWS S3 ────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=synapse-files
AWS_S3_CUSTOM_DOMAIN=
USE_S3=False

# ── Cloud Storage: Google Drive ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth2-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth2-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/drive/callback/

# ── Google OAuth (frontend Sign-In with Google) ──────────────
# ⚠️  NEXT_PUBLIC_* values are baked into the frontend JS bundle at build time.
# You MUST set this in your Vercel project (Frontend) for the "Sign in with
# Google" button to work — without it the button is disabled.
# Get the Client ID at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:  http://localhost:3000  (and your Vercel URL)
# Authorized redirect URIs:       not needed for the implicit token flow used here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── GitHub OAuth ─────────────────────────────────────────────
# Set GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET on the Django backend (Render).
# The frontend "Sign in with GitHub" button is enabled automatically as long as
# NEXT_PUBLIC_API_URL is set — it just redirects to the backend OAuth endpoint.
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# The redirect URI registered in your GitHub OAuth App MUST exactly match this
# value, including https:// in production. Example for Render:
# GITHUB_REDIRECT_URI=https://your-backend.onrender.com/api/v1/auth/github/callback/
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback/
# Twitter/X API v2 Bearer Token (replaces Nitter)
TWITTER_BEARER_TOKEN=your-twitter-api-v2-bearer-token

# ── Stripe Billing ───────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
# Price IDs from your Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id
STRIPE_ENT_PRICE_ID=price_your_enterprise_monthly_price_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual_price_id
# Public key for frontend Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ── AI Guardrails ─────────────────────────────────────────────
AI_BUDGET_FREE_CENTS=50
AI_BUDGET_PRO_CENTS=1000
AI_RATE_LIMIT_FREE=2
AI_RATE_LIMIT_PRO=20
AI_RATE_LIMIT_TEAM=60

# ── Sentry Error Monitoring ───────────────────────────────────
# Shared DSN used by both Django backend and Next.js frontend
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# Optional: tune sample rates (defaults shown)
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_RATE=0.01
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_RATE=0.1
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# CI/CD: source-map upload (never expose in client bundle)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=synapse-frontend
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# ── Analytics (Phase 9.2) ─────────────────────────────────────
POSTHOG_API_KEY=phc_your_posthog_project_api_key
POSTHOG_HOST=https://app.posthog.com
ANALYTICS_ENABLED=true
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Email / Notifications ────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@synapse.ai
SUPPORT_EMAIL=support@synapse.ai

# ── JWT Authentication ───────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=your-jwt-signing-key-different-from-secret-key

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SYNAPSE

# ── FastAPI AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_PORT=8001

# ── Monitoring / Observability ───────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
PROMETHEUS_METRICS_ENABLED=True

# ── Security ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
RATE_LIMIT_FREE=100/minute
RATE_LIMIT_PRO=1000/minute
RATE_LIMIT_AI=10/minute
LOGIN_MAX_ATTEMPTS=5
LOGIN_COOLDOWN_MINUTES=15

# ── Celery ───────────────────────────────────────────────────
CELERY_WORKERS=4
CELERY_MAX_TASKS_PER_CHILD=1000
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:flower_password

# ── Feature Flags ────────────────────────────────────────────
ENABLE_SCRAPING=True
ENABLE_NLP=True
ENABLE_AI_CHAT=True
ENABLE_AGENTS=True
ENABLE_GOOGLE_DRIVE=False
ENABLE_S3=False
ENABLE_NOTIFICATIONS=True
